# OpenTryRW runtime
OPENTRYRW_IMAGE=ghcr.io/celestialhq/opentryrw:local
OPENTRYRW_DB=/app/data/opentryrw.json
FRONTEND_ORIGIN=https://opentryrw.example.com
COOKIE_SECURE=true

# Caddy reverse proxy
CADDY_SITE_ADDRESS=opentryrw.example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Database
STORAGE_BACKEND=postgres
RUN_MIGRATIONS=true
DATABASE_URL=postgresql+asyncpg://opentryrw:opentryrw@postgres:5432/opentryrw
DATABASE_ECHO=false
POSTGRES_DB=opentryrw
POSTGRES_USER=opentryrw
POSTGRES_PASSWORD=opentryrw

# Service policy
DEPLOYMENT_PROVIDER=mock
# Recommended beta value: 1-3.
MAX_ACTIVE_INSTANCES=10
SESSION_COOLDOWN_SECONDS=86400
FINGERPRINT_COOLDOWN_SECONDS=86400
CLEANUP_INTERVAL_SECONDS=30
DEPLOYMENT_HEALTH_TIMEOUT_SECONDS=600
PROVIDER_REFRESH_INTERVAL_SECONDS=10
RECONCILIATION_INTERVAL_SECONDS=300
STALE_RESOURCE_GRACE_SECONDS=900
WORKER_ID=opentryrw-worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=4
WORKER_LOCK_SECONDS=120
# Set a random 32+ character value in beta/prod.
ABUSE_HASH_SECRET=
TRUST_PROXY_HEADERS=true
RATE_LIMIT_AUTH_START_PER_MINUTE=12
RATE_LIMIT_AUTH_CALLBACK_PER_MINUTE=20
RATE_LIMIT_SESSION_CREATE_PER_HOUR=6
RATE_LIMIT_SESSION_DELETE_PER_MINUTE=10

# Telegram OIDC auth
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_REDIRECT_URI=https://opentryrw.example.com/api/auth/telegram/callback

# Telegram notifications
# TELEGRAM_OPERATOR_CHAT_ID supports topics: -1001234567890:42
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# DigitalOcean provider
# Set DEPLOYMENT_PROVIDER=digitalocean above to enable real Droplet deployments.
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_REGION=fra1
DIGITALOCEAN_SIZE=s-1vcpu-2gb
DIGITALOCEAN_IMAGE=ubuntu-24-04-x64
DIGITALOCEAN_SSH_KEYS=
DIGITALOCEAN_TAG_PREFIX=opentryrw

# Public deployment URLs
# Cloudflare creates proxied A records when all three Cloudflare values are set.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ROOT_DOMAIN=
CLOUDFLARE_RECORD_TTL=1
DEPLOYMENT_PUBLIC_DOMAIN_TEMPLATE={ip}.sslip.io

# Remnawave install sources
REMNAWAVE_STABLE_COMPOSE_URL=https://raw.githubusercontent.com/remnawave/backend/refs/heads/main/docker-compose-prod.yml
REMNAWAVE_DEV_COMPOSE_URL=https://gist.githubusercontent.com/pius-pp/7ab391dc9659200cd22e1522d0b77582/raw/520f47cf546bd5802f298f23c399781ad6a55f4f/docker-compose-dev.yml
REMNAWAVE_ENV_SAMPLE_URL=https://raw.githubusercontent.com/remnawave/backend/refs/heads/main/.env.sample
